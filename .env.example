# App Store Connect API Key
ASC_KEY_ID="YOUR_KEY_ID"
ASC_ISSUER_ID="YOUR_ISSUER_ID"
# Content of the .p8 file. Use \n for newlines if needed, or point to a file.
# Fastlane often prefers the file path or raw content.
ASC_KEY_CONTENT="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----"

# Local Godot Path (e.g. /Applications/Godot.app/Contents/MacOS/Godot)
GODOT_PATH="/Applications/Godot.app/Contents/MacOS/Godot"
