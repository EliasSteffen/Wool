default_platform(:ios)

platform :ios do
  desc "Build and Upload to TestFlight"
  lane :release do
    # 0. Load secrets from environment (already handled by dotenv in shell script, but good to ensure)

    # 1. Export Godot Project
    # We call Godot headless to ensure the Xcode project is fresh
    UI.message "Godot Path: #{ENV['GODOT_PATH']}"
    if ENV['GODOT_PATH'].to_s.empty?
      UI.user_error! "GODOT_PATH not set in .env"
    end

    UI.message "🏗️  Exporting Godot Project..."
    sh("#{ENV['GODOT_PATH']} --headless --path . --export-release 'iOS' 'build/ios/Wool.ipa' || true")

    # 2. Sync Certificates (Disabled: We use local keychain)
    # match(type: "appstore", readonly: true)

    # 3. Build IPA
    gym(
      project: "./build/ios/Wool.xcodeproj",
      scheme: "Wool",
      export_method: "app-store",
      output_directory: "./build/ios",
      output_name: "Wool.ipa",
      clean: true
    )

    # 4. Upload
    # Create the API Key object for Fastlane

    api_key_input = ENV["ASC_KEY_CONTENT"]
    key_content = ""

    UI.message("Current Dir: #{Dir.pwd}")
    UI.message("API Key Input: #{api_key_input}")

    # Check for file existence (Fastlane usually runs in ./fastlane)
    if api_key_input && File.exist?(api_key_input)
      UI.message("Found key file at: #{api_key_input}")
      key_content = File.read(api_key_input)
    elsif api_key_input && File.exist?("../#{api_key_input}")
       UI.message("Found key file at: ../#{api_key_input}")
       key_content = File.read("../#{api_key_input}")
    elsif api_key_input && File.exist?(File.expand_path(api_key_input))
       UI.message("Found key file at: #{File.expand_path(api_key_input)}")
       key_content = File.read(File.expand_path(api_key_input))
    else
      UI.message("Key file not found or input is raw content. Treating as content.")
      # User provided raw content, sanitize newlines
      key_content = api_key_input.to_s.gsub("\\n", "\n")
    end

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: key_content,
      duration: 1200,
      in_house: false
    )

    pilot(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
